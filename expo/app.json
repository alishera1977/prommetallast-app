{
  "expo": {
    "name": "Промметпласт app store",
    "slug": "prommetplast",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "prommetplast",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.prommetplast.mobile",
      "infoPlist": {
        "NSCameraUsageDescription": "Камера нужна, чтобы сфотографировать металлолом для предварительной оценки.",
        "NSPhotoLibraryUsageDescription": "Доступ к фото нужен, чтобы выбрать изображение металлолома для предварительной оценки."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "ru.prommetplast.app"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://rork.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}